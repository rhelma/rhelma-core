{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local",
    "Cargo.toml",
    "Cargo.lock",
    "docs/contract/**",
    "crates/**"
  ],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "build/**",
        ".svelte-kit/**",
        "target/**",
        ".wrangler/**",
        "!.turbo/**"
      ],
      "outputMode": "full"
    },

    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },

    "dev:edge": {
      "cache": false,
      "persistent": true
    },

    "dev:web": {
      "cache": false,
      "persistent": true
    },

    "lint": {
      "outputs": [],
      "dependsOn": []
    },

    "type-check": {
      "dependsOn": ["^build"],
      "outputs": ["node_modules/.cache/tsbuildinfo"]
    },

    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },

    "test:watch": {
      "cache": false,
      "persistent": true
    },

    "clean": {
      "cache": false
    },

    "//#proto:generate": {
      "dependsOn": [],
      "outputs": [
        "packages/types/src/gen/**",
        "crates/rhelma-events/src/gen/**"
      ]
    },

    "//#cargo:check": {
      "dependsOn": ["//#proto:generate"],
      "outputs": [".cargo/**", "target/**"]
    },

    "deploy:edge": {
      "dependsOn": ["build"],
      "cache": false
    },

    "deploy:api": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
