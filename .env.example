# Rhelma Core - Public Development Environment Example
# No production secrets or commercial settings are included.

RHELMA_ENV=development
RUST_LOG=info

# Local development database
DATABASE_URL=postgres://rhelma:rhelma@localhost:5432/rhelma

# Optional local cache
REDIS_URL=redis://localhost:6379

# Service identity (development only)
SERVICE_NAME=rhelma-example
SERVICE_VERSION=0.1.0

# Event development mode
RHELMA_EVENT_MODE=local

# Generate your own values for local development when required.
# Never commit real secrets.
JWT_SECRET=change-me-in-development
