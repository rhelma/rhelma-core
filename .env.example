# Rhelma public core example environment.
# Copy to .env for local development. Do not commit real secrets.

RHELMA_ENV=development
RHELMA_SERVICE_NAME=rhelma-public-core
RHELMA_REGION=local
RHELMA_TENANT_ID=00000000-0000-0000-0000-000000000001

# Database
DATABASE_URL=postgres://rhelma_user:password@127.0.0.1:5432/rhelma_platform
RHELMA_DB__URL=postgres://rhelma_user:password@127.0.0.1:5432/rhelma_platform

# Redis
RHELMA_REDIS__URL=redis://127.0.0.1:6379/0
RHELMA_REDIS_URL=redis://127.0.0.1:6379/0

# NATS / event transport
NATS_URL=nats://127.0.0.1:4222
RHELMA_NATS_URL=nats://127.0.0.1:4222

# API gateway
RHELMA_API_GATEWAY__BIND=127.0.0.1:8080
RHELMA_API_GATEWAY__PUBLIC_BASE_URL=http://127.0.0.1:8080
RHELMA_API_GATEWAY__CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Social service
RHELMA_SOCIAL__BIND=127.0.0.1:8091
RHELMA_SOCIAL__DATABASE_URL=postgres://rhelma_user:password@127.0.0.1:5432/rhelma_platform
RHELMA_SOCIAL__REDIS_URL=redis://127.0.0.1:6379/0

# Search service
RHELMA_SEARCH__BIND=127.0.0.1:8092
RHELMA_SEARCH_DATABASE_URL=postgres://rhelma_user:password@127.0.0.1:5432/rhelma_platform
RHELMA_SEARCH_REDIS_URL=redis://127.0.0.1:6379/0

# Realtime service
RHELMA_REALTIME__BIND=127.0.0.1:8093
RHELMA_REALTIME__REDIS_URL=redis://127.0.0.1:6379/0

# File storage
RHELMA_FILE_STORAGE__BIND=127.0.0.1:8094
RHELMA_FILE_STORAGE__DATABASE_URL=postgres://rhelma_user:password@127.0.0.1:5432/rhelma_platform
RHELMA_FILE_STORAGE__LOCAL_DIR=./data/files
RHELMA_FILE_STORAGE__MAX_UPLOAD_BYTES=10485760

# Node registry
RHELMA_NODE_REGISTRY__BIND=127.0.0.1:8095
RHELMA_NODE_REGISTRY__REDIS_URL=redis://127.0.0.1:6379/0

# Auth
# Generate real local keys before enabling signed auth flows.
# RHELMA_AUTH_JWT_PRIVATE_KEY_B64=
# RHELMA_AUTH_JWT_PUBLIC_KEY_B64=
RHELMA_AUTH_TOKEN_TTL_SECONDS=3600

# Observability
RUST_LOG=info
RHELMA_LOG_FORMAT=pretty
RHELMA_METRICS_BIND=127.0.0.1:9100
