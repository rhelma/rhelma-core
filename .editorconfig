# EditorConfig helps developers maintain consistent coding styles between editors.
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{rs,toml,yml,yaml,json,md,sh,ps1}]
indent_style = space
indent_size = 4

[*.rs]
max_line_length = 100

[*.md]
trim_trailing_whitespace = false
max_line_length = 120
